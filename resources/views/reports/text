   public function index(Request $request)
{
    // جلب التراخيص مع علاقة الشركة
    $query = License::with('company'); 

    // تطبيق البحث
    $query->when($request->search, function ($q) use ($request) {
        return $q->where('license_number', 'like', '%' . $request->search . '%') // رقم الترخيص
                 ->orWhereHas('company', function($subQuery) use ($request) {
                     $subQuery->where('name', 'like', '%' . $request->search . '%'); // اسم الشركة
                 });
    });

    $licenses = $query->latest()->paginate(10);

        return view('companies.licenses.index', compact('licenses'));
    }